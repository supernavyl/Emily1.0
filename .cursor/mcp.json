{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Live library documentation from 10,000+ packages"
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "/home/supernovyl/Emily1.0/data/interactions.db"
      ],
      "description": "Query Emily's interaction database"
    },
    "sqlite-episodes": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "/home/supernovyl/Emily1.0/data/episodes.db"
      ],
      "description": "Query Emily's episodic memory database"
    },
    "sqlite-knowledge": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "/home/supernovyl/Emily1.0/data/knowledge.db"
      ],
      "description": "Query Emily's knowledge store"
    },
    "qdrant": {
      "command": "npx",
      "args": ["-y", "@qdrant/mcp-server-qdrant"],
      "env": {
        "QDRANT_URL": "http://localhost:6333",
        "COLLECTION_NAME": "emily_semantic"
      },
      "description": "Vector search in Emily's semantic memory (Qdrant)"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "Fetch web pages and convert to markdown"
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "/home/supernovyl/Emily1.0"
      ],
      "description": "Git operations on Emily repository"
    },
    "time": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "description": "Timezone and temporal operations"
    }
  }
}
