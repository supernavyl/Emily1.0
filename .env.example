# Emily Environment Configuration
# Copy to .env and fill in your values

# --- Core ---
EMILY_LOG_LEVEL=INFO
EMILY_DATA_DIR=data
EMILY_LOGS_DIR=logs

# --- LLM ---
EMILY_LLM__OLLAMA_BASE_URL=http://localhost:11434
EMILY_LLM__TABBYAPI_BASE_URL=http://localhost:5000
EMILY_LLM__TABBYAPI_API_KEY=

# --- Emily Chat (TabbyAPI provider) ---
TABBYAPI_HOST=http://localhost:5000/v1
TABBYAPI_API_KEY=

# --- API ---
EMILY_API__SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
EMILY_API__HOST=127.0.0.1
EMILY_API__PORT=8000

# --- Home Assistant ---
EMILY_TOOLS__HOME_ASSISTANT__TOKEN=your_long_lived_ha_token_here

# --- Security ---
EMILY_SECURITY__KEY_FILE=~/.emily_key

# --- Observability ---
EMILY_OBSERVABILITY__OTLP_ENDPOINT=http://localhost:4317

# --- MCP Servers ---
# GitHub integration for MCP server
GITHUB_TOKEN=your_github_personal_access_token_here

# Brave Search API for MCP server
BRAVE_API_KEY=your_brave_search_api_key_here

# PostgreSQL connection for MCP server
POSTGRES_URL=postgresql://username:password@hostname:port/database

# n8n workflow automation (optional)
N8N_API_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key-here

# Cloudflare API credentials
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Slack integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_USER_TOKEN=xoxp-your-slack-user-token-here
